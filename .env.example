# Copy this file to .env for local testing with: npx vercel dev
# On Vercel: Project → Settings → Environment Variables (same names)

# Required — from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Required — must be a verified sender in Resend (e.g. "Sanchez Landscape <hello@yourdomain.com>")
# For Resend's test domain only: use onboarding@resend.dev and send TO the same email you signed up with
RESEND_FROM=Sanchez Landscape <onboarding@resend.dev>

# reCAPTCHA (pick ONE backend — client loads the matching Google script)
# Public site key (required for either option). Often named NEXT_PUBLIC_* on Vercel.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Optional alias if you do not use NEXT_PUBLIC_* :
# RECAPTCHA_SITE_KEY=

# Option A — reCAPTCHA Enterprise (GCP assessment API). This is what the project used before.
# RECAPTCHA_API_KEY=
# RECAPTCHA_PROJECT_ID=sanchez-landscape-492713
# Optional: minimum risk score; submission must score ABOVE this (default 0.5)
# RECAPTCHA_MIN_SCORE=0.5

# Option B — Classic reCAPTCHA v3 (secret from Google admin → siteverify)
# RECAPTCHA_SECRET_KEY=

# Optional — where form submissions go (defaults to sanchezlandscape512@gmail.com)
# Use two addresses in one variable (comma or semicolon), and/or add a second env var:
# CONTACT_TO_EMAIL=you@example.com,partner@example.com
# CONTACT_TO_EMAIL_2=backup@example.com
